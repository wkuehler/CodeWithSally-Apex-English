<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Is_Active__c</fullName>
    <label>Is Active</label>
    <type>Checkbox</type>
    <formulaTreatBlanksAs>BlankAsBlank</formulaTreatBlanksAs>
    <formula>AND(TODAY() &gt;= Start_Date__c, TODAY() &lt;= End_Date__c)</formula>
    <inlineHelpText>True when today falls within the quest start and end dates.</inlineHelpText>
</CustomField>
