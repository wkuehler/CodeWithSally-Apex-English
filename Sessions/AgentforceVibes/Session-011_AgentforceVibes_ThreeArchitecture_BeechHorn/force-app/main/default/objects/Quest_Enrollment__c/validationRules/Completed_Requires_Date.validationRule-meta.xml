<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Completed_Requires_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status__c, 'Completed'), ISBLANK(Completed_Date__c))</errorConditionFormula>
    <errorMessage>Completed Date is required when status is Completed.</errorMessage>
</ValidationRule>
